<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/listFragment">

    <fragment
        android:id="@+id/listFragment"
        android:name="com.mas.quranwords.ui.ListFragment"
        android:label="List">

        <action
            android:id="@+id/action_listFragment_to_detailFragment"
            app:destination="@id/detailFragment"/>

        <action
            android:id="@+id/action_listFragment_to_numbersFragment"
            app:destination="@id/numbersFragment"/>

    </fragment>

    <fragment
        android:id="@+id/detailFragment"
        android:name="com.mas.quranwords.ui.DetailFragment"
        android:label="Detail"/>

    <fragment
        android:id="@+id/numbersFragment"
        android:name="com.mas.quranwords.ui.NumbersFragment"
        android:label="Numbers"/>

    <fragment
        android:id="@+id/wordListFragment"
        android:name="com.mas.quranwords.ui.words.WordListFragment"
        android:label="Numbers"/>

    <fragment
        android:id="@+id/addWordFragment"
        android:name="com.mas.quranwords.ui.words.AddWordFragment">
        <argument
            android:name="wordId"
            app:argType="long"/>
    </fragment>

    <fragment
        android:id="@+id/editWordFragment"
        android:name="com.mas.quranwords.ui.words.EditWordFragment">
        <argument
            android:name="wordId"
            app:argType="long"/>
    </fragment>

    <fragment
        android:id="@+id/localDetailFragment"
        android:name="com.mas.quranwords.ui.words.LocalDetailFragment"
        android:label="Local Detail">
        <argument
            android:name="wordId"
            app:argType="long"/>

    </fragment>

</navigation>