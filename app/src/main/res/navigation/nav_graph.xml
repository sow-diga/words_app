<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/listFragment">

    <fragment
        android:id="@+id/listFragment"
        android:name="com.mas.quranwords.ui.ListFragment"
        android:label="List">

        <action
            android:id="@+id/action_listFragment_to_detailFragment"
            app:destination="@id/detailFragment"/>

        <action
            android:id="@+id/action_listFragment_to_numbersFragment"
            app:destination="@id/numbersFragment"/>

    </fragment>

    <fragment
        android:id="@+id/detailFragment"
        android:name="com.mas.quranwords.ui.DetailFragment"
        android:label="Detail"/>

    <fragment
        android:id="@+id/numbersFragment"
        android:name="com.mas.quranwords.ui.NumbersFragment"
        android:label="Numbers"/>

</navigation>