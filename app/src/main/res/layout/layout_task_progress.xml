<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/progressCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title / Current Phase Header -->
        <TextView
            android:id="@+id/phaseHeaderTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phase 1: Listening"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tapInstructionTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tap anywhere on the screen to count"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="14sp" />
        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="@dimen/margin_top"
            android:background="#E0E0E0" />

        <!-- Phase 1: Listening Progress Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/listenTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Listen"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/listenCountTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 5"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/listenProgressIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:max="5"
            app:indicatorColor="@color/primary"
            app:trackColor="#E0E0E0"
            app:trackCornerRadius="8dp"
            app:trackThickness="10dp" />

        <!-- Phase 2: Repeating Progress Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_top"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/repeatTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Repeat"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/repeatCountTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 10"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/repeatProgressIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:max="10"
            app:indicatorColor="@color/primary"
            app:trackColor="#E0E0E0"
            app:trackCornerRadius="8dp"
            app:trackThickness="10dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>