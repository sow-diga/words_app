<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:gravity="center_vertical">

    <!-- Optional: A nice icon next to the reciter's name -->
    <ImageView
        android:id="@+id/itemReciterIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="12dp"
        android:src="@android:drawable/ic_btn_speak_now"
        android:contentDescription="Reciter Icon" />

    <!-- CRUCIAL: The TextView where the text will go -->
    <TextView
        android:id="@+id/itemReciterName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#1A1C1E"
        android:textSize="16sp" />

</LinearLayout>